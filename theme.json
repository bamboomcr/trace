    "styles": {
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--google-sans-flex)",
            "fontSize": "var(--wp--preset--font-size--m)",
            "lineHeight": "var(--wp--preset--line-height--body)"
        },
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--foreground)"
        },
        "spacing": {
            "padding": {
                "top": "0",
                "right": "var(--wp--style--root--padding-right)",
                "bottom": "0",
                "left": "var(--wp--style--root--padding-left)"
            }
        },
        "elements": {
            "heading": {
                "color": {
                    "text": "var(--wp--preset--color--heading)"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--space-grotesk)",
                    "fontWeight": "400",
                    "lineHeight": "var(--wp--preset--line-height--headings)",
                    "letterSpacing": "var(--wp--preset--letter-spacing--slight)"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--foreground)"
                },
                "typography": {
                    "textDecoration": "underline"
                }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--foreground)",
                    "text": "var(--wp--preset--color--background)"
                },
                "border": {
                    "radius": "999px"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--space-grotesk)",
                    "fontWeight": "500",
                    "lineHeight": "1.2",
                    "letterSpacing": "var(--wp--preset--letter-spacing--normal)"
                }
            }
        },
        "blocks": {
            "core/group": {
                "variations": [
                    {
                        "name": "card",
                        "title": "Card",
                        "styles": {
                            "border": {
                                "width": "1px",
                                "radius": "0.75rem"
                            },
                            "spacing": {
                                "padding": {
                                    "top": "var(--wp--preset--spacing--m)",
                                    "right": "var(--wp--preset--spacing--m)",
                                    "bottom": "var(--wp--preset--spacing--m)",
                                    "left": "var(--wp--preset--spacing--m)"
                                }
                            }
                        }
                    }
                ]
            },
            "core/heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--space-grotesk)",
                    "lineHeight": "var(--wp--preset--line-height--headings)"
                },
                "elements": {
                    "h1": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--heading-xl)"
                        }
                    },
                    "h2": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--heading-l)"
                        }
                    },
                    "h3": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--heading-m)"
                        }
                    },
                    "h4": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--l)"
                        }
                    },
                    "h5": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--m)"
                        }
                    },
                    "h6": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--s)"
                        }
                    }
                }
            },
            "core/paragraph": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--google-sans-flex)"
                }
            },
            "core/button": {
                "color": {
                    "background": "var(--wp--preset--color--foreground)",
                    "text": "var(--wp--preset--color--background)"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--space-grotesk)",
                    "fontWeight": "500"
                }
            },
            "core/navigation": {
                "spacing": {
                    "blockGap": "1rem"
                }
            },
            "core/list": {
                "variations": {
                    "styles": [
                        {
                            "name": "default",
                            "label": "Default",
                            "isDefault": true
                        },
                        {
                            "name": "no-markers",
                            "label": "No bullets / numbers"
                        }
                    ]
                }
            },
            "core/latest-posts": {
                "spacing": {
                    "margin": true,
                    "padding": true,
                    "__experimentalDefaultControls": {
                        "margin": true,
                        "padding": true
                    }
                }
            }
        }
    }
}