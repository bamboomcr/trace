                },
                "spacing": {
                    "margin": true,
                    "padding": true,
                    "blockGap": true
                }
            }
        },
        "custom": {
            "motion": {
                "duration-fast": "300ms",
                "duration-base": "600ms",
                "duration-slow": "1200ms",
                "ease-out": "cubic-bezier(0.22, 1, 0.36, 1)",
                "ease-soft": "cubic-bezier(0.25, 0.1, 0.25, 1)",
                "parallax-distance": "2px",
                "hover-lift": "4px"
            }
        }
